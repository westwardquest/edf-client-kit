# Safe to commit as warpdesk.config.example. Copy to warpdesk.config (gitignored) and fill secrets.
# Quickstart generates warpdesk.config + a workspace-specific warpdesk.config.example.

WORKSPACE_NAME="Your workspace display name"
WORKSPACE_SLUG=your-workspace-slug
DEV_APP_ORIGIN=https://your-warpdesk-deployment.example
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
GITHUB_OWNER=
KNOWLEDGE_REPO_HTTPS=
GITHUB_WEBHOOK_SECRET=
# Published kit (override if you fork — quickstart reads .gitmodules / WARPDESK_CLIENT_KIT_GIT_URL)
WARPDESK_CLIENT_KIT_GIT_URL=
